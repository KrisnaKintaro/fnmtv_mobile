<resources xmlns:tools="http://schemas.android.com/tools">

    <style name="Base.Theme.FnmtvMobile" parent="Theme.Material3.Light.NoActionBar">
        <item name="colorPrimary">@color/red_primary</item>
        <item name="colorOnPrimary">@color/white_pure</item>
        <item name="android:windowBackground">@color/bg_cream</item>
        <item name="android:statusBarColor">@color/red_dark</item>
        <item name="actionOverflowMenuStyle">@style/RedOverflowMenu</item>
        <!-- Dan pastikan popup theme-nya juga mengarah ke merah -->
        <item name="actionBarPopupTheme">@style/RedPopupMenu</item>
    </style>

    <style name="Theme.FnmtvMobile" parent="Base.Theme.FnmtvMobile" />

    <style name="RedOverflowMenu" parent="Widget.Material3.PopupMenu.Overflow">
        <item name="android:overlapAnchor">false</item>
        <item name="android:dropDownVerticalOffset">5dp</item>
        <!-- Kalau mau geser horizontal juga bisa: -->
        <!-- <item name="android:dropDownHorizontalOffset">-10dp</item> -->
    </style>

    <style name="RedPopupMenu" parent="ThemeOverlay.Material3.Dark">
        <!-- Ini kunci buat background di Material 3 -->
        <item name="colorSurface">@color/red_primary</item>
        <item name="colorSurfaceContainer">@color/red_primary</item>
        <item name="android:colorBackground">@color/red_primary</item>
        <item name="android:popupBackground">@color/red_primary</item>

        <!-- Warna text & icon -->
        <item name="colorOnSurface">@color/white_pure</item>
        <item name="android:textColor">@color/white_pure</item>
        <item name="android:textColorPrimary">@color/white_pure</item>
    </style>
</resources>