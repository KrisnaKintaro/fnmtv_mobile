<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="@color/fnm_bg">

    <include
        android:id="@+id/heroSection"
        layout="@layout/layout_hero_section" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginTop="24dp"
        android:layout_marginBottom="12dp">

        <View android:layout_width="4dp" android:layout_height="22dp" android:background="@color/fnm_red" android:layout_marginEnd="8dp"/>

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Berita Terbaru" android:textColor="@color/fnm_text" android:textSize="18sp" android:textStyle="bold" android:fontFamily="serif"/>

        <Space android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"/>

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Lihat Semua ➔" android:textColor="@color/fnm_red" android:textSize="12sp" android:textStyle="bold"/>
    </LinearLayout>

    <View android:layout_width="match_parent" android:layout_height="2dp" android:background="@color/fnm_text" android:layout_marginBottom="16dp"/>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvBeritaTerbaru"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:nestedScrollingEnabled="false" />

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:layout_marginVertical="24dp"
        android:background="#E0E0E0">
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Space Iklan 728x90" android:layout_gravity="center" android:textColor="@color/fnm_muted" android:textSize="12sp"/>
    </FrameLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:background="@drawable/bg_dialog_rounded"
        android:backgroundTint="@color/fnm_white"
        android:orientation="vertical"
        android:padding="16dp"
        android:elevation="1dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="📈 Sedang Tren"
            android:textColor="@color/fnm_text"
            android:textSize="16sp"
            android:textStyle="bold"
            android:fontFamily="serif"
            android:layout_marginBottom="16dp"/>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvTrending"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:nestedScrollingEnabled="false"/>
    </LinearLayout>

</LinearLayout>