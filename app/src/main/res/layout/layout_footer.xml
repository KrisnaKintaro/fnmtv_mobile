<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/fnm_text"
    android:orientation="vertical"
    android:paddingHorizontal="20dp"
    android:paddingTop="36dp"
    android:paddingBottom="14dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="FNM"
        android:textColor="@color/fnm_red"
        android:textSize="28sp"
        android:textStyle="bold"
        android:fontFamily="serif"
        android:textAlignment="center"/>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="Fenomena News Media — Delivering unbiased, in-depth reporting on the stories that shape our world."
        android:textColor="#AAAAAA"
        android:textSize="13sp"
        android:lineSpacingExtra="4dp"
        android:textAlignment="center"
        android:layout_marginBottom="24dp"/>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="KATEGORI"
        android:textColor="#AAAAAA"
        android:textSize="12sp"
        android:textStyle="bold"
        android:letterSpacing="0.1"
        android:textAlignment="center"
        android:layout_marginBottom="12dp"/>

    <LinearLayout
        android:id="@+id/footerCategoryContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">
    </LinearLayout>

    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#2A2A2A" android:layout_marginVertical="14dp"/>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="© 2026 Fenomena News Media. All rights reserved."
        android:textColor="#555555"
        android:textSize="12sp"
        android:textAlignment="center"/>

</LinearLayout>