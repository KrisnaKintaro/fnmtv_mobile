<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_dialog_rounded"
    android:padding="24dp">

    <TextView
        android:id="@+id/tv_dialog_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Tambah Pengguna Baru"
        android:textColor="#1A1A1A"
        android:textSize="18sp"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/tv_dialog_subtitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="Masukkan detail informasi pengguna di bawah ini."
        android:textColor="#7A7570"
        android:textSize="13sp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tv_dialog_title" />

    <TextView
        android:id="@+id/lbl_username"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:text="Username *"
        android:textColor="#1A1A1A"
        android:textSize="12sp"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tv_dialog_subtitle" />

    <EditText
        android:id="@+id/et_form_username"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginTop="6dp"
        android:background="#F5F4F0"
        android:hint="contoh: krisna_kintaro"
        android:paddingHorizontal="12dp"
        android:textColorHint="#A09C98"
        android:textSize="14sp"
        app:layout_constraintTop_toBottomOf="@id/lbl_username" />

    <TextView
        android:id="@+id/lbl_email"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="Email *"
        android:textColor="#1A1A1A"
        android:textSize="12sp"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/et_form_username" />

    <EditText
        android:id="@+id/et_form_email"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginTop="6dp"
        android:background="#F5F4F0"
        android:hint="contoh: krisna@fnm.com"
        android:inputType="textEmailAddress"
        android:paddingHorizontal="12dp"
        android:textColorHint="#A09C98"
        android:textSize="14sp"
        app:layout_constraintTop_toBottomOf="@id/lbl_email" />

    <TextView
        android:id="@+id/lbl_password_user"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="Password"
        android:textColor="#1A1A1A"
        android:textSize="12sp"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/et_form_email" />

    <EditText
        android:id="@+id/et_form_password"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginTop="6dp"
        android:background="#F5F4F0"
        android:hint="Masukkan password..."
        android:inputType="textPassword"
        android:paddingHorizontal="12dp"
        android:textColor="#1A1A1A"
        android:textSize="14sp"
        app:layout_constraintTop_toBottomOf="@id/lbl_password_user" />

    <TextView
        android:id="@+id/lbl_role"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="Role Pengguna *"
        android:textColor="#1A1A1A"
        android:textSize="12sp"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/et_form_password" />

    <Spinner
        android:id="@+id/spin_form_role"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginTop="6dp"
        android:background="#F5F4F0"
        app:layout_constraintTop_toBottomOf="@id/lbl_role" />

    <TextView
        android:id="@+id/lbl_status"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="Status Akun *"
        android:textColor="#1A1A1A"
        android:textSize="12sp"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/spin_form_role" />

    <RadioGroup
        android:id="@+id/rg_status"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:orientation="horizontal"
        app:layout_constraintTop_toBottomOf="@id/lbl_status">

        <RadioButton
            android:id="@+id/rb_aktif"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:buttonTint="#CC0000"
            android:text="Aktif"
            android:textColor="#1A1A1A"
            android:textSize="14sp" />

        <RadioButton
            android:id="@+id/rb_nonaktif"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="24dp"
            android:buttonTint="#CC0000"
            android:text="Nonaktif"
            android:textColor="#1A1A1A"
            android:textSize="14sp" />
    </RadioGroup>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:orientation="horizontal"
        android:weightSum="2"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/rg_status">

        <Button
            android:id="@+id/btn_batal_user"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:layout_marginEnd="8dp"
            android:layout_weight="1"
            android:backgroundTint="#E0DDD6"
            android:text="Batal"
            android:textColor="#1A1A1A"
            android:textStyle="bold" />

        <Button
            android:id="@+id/btn_simpan_user"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:layout_marginStart="8dp"
            android:layout_weight="1"
            android:backgroundTint="#CC0000"
            android:text="Simpan Data"
            android:textColor="#FFFFFF"
            android:textStyle="bold" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>