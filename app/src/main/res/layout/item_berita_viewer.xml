<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingVertical="12dp"
    android:background="?attr/selectableItemBackground"
    android:clickable="true"
    android:focusable="true">

    <androidx.cardview.widget.CardView
        android:id="@+id/cvThumbnail"
        android:layout_width="110dp"
        android:layout_height="80dp"
        app:cardCornerRadius="8dp"
        app:cardElevation="0dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent">

        <ImageView
            android:id="@+id/ivThumbnail"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"
            android:background="@color/fnm_border" />
    </androidx.cardview.widget.CardView>

    <TextView
        android:id="@+id/tvKategori"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:text="KATEGORI"
        android:textColor="@color/fnm_red"
        android:textSize="11sp"
        android:textStyle="bold"
        app:layout_constraintStart_toEndOf="@id/cvThumbnail"
        app:layout_constraintTop_toTopOf="@id/cvThumbnail" />

    <TextView
        android:id="@+id/tvJudulBerita"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:layout_marginTop="4dp"
        android:text="Judul Berita Memuat..."
        android:textColor="@color/fnm_text"
        android:textSize="14sp"
        android:textStyle="bold"
        android:fontFamily="serif"
        android:maxLines="2"
        android:ellipsize="end"
        android:lineSpacingExtra="2dp"
        app:layout_constraintStart_toEndOf="@id/cvThumbnail"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvKategori" />

    <TextView
        android:id="@+id/tvTanggal"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:text="12 Mei 2026 · 👁 1.2k views"
        android:textColor="@color/fnm_muted"
        android:textSize="11sp"
        app:layout_constraintStart_toEndOf="@id/cvThumbnail"
        app:layout_constraintBottom_toBottomOf="@id/cvThumbnail" />

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginTop="12dp"
        android:background="@color/fnm_border"
        app:layout_constraintTop_toBottomOf="@id/cvThumbnail"
        app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>